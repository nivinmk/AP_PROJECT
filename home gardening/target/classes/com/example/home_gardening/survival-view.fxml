<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER"
      spacing="20"
      prefWidth="1000"
      prefHeight="600"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.home_gardening.SurvivalController"
      style="-fx-background-color:#DDEEDB;">

    <padding>
        <Insets top="40"/>
    </padding>

    <Label text="Plant Survival Score 📊"
           style="-fx-font-size:30px; -fx-font-weight:bold;"/>

    <!-- Plant Name -->
    <TextField fx:id="plantName"
               promptText="Enter Plant Name"
               prefWidth="300"
               maxWidth="300"/>

    <!-- Sunlight -->
    <ComboBox fx:id="sunlightBox"
              promptText="Sunlight Available"
              prefWidth="220"/>

    <!-- Water -->
    <ComboBox fx:id="waterBox"
              promptText="Water Availability"
              prefWidth="220"/>

    <!-- Space -->
    <ComboBox fx:id="spaceBox"
              promptText="Space Available"
              prefWidth="220"/>

    <!-- Predict Button -->
    <Button text="Predict Survival"
            onAction="#predictSurvival"
            prefWidth="200"
            prefHeight="50"/>

    <!-- Result -->
    <Label fx:id="resultLabel"
           text=""
           style="-fx-font-size:18px; -fx-text-fill:green;"/>

    <!-- Back Button -->
    <Button text="← Back"
            onAction="#goBack"
            prefWidth="120"
            prefHeight="40"/>

</VBox>